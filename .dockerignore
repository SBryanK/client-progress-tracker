# Next.js build output (rebuilt inside the image)
.next
out

# Node
node_modules
npm-debug.log
yarn-error.log
pnpm-debug.log

# Local SQLite DB / state (we use a named docker volume at runtime instead)
prisma/dev.db
prisma/dev.db-journal

# Git / editor
.git
.gitignore
.gitattributes
.vscode
.idea
.cursor

# OS
.DS_Store
Thumbs.db
*.log

# Docs / large binaries we don't need at runtime
README.md
*.docx
*.pdf

# Environment files — passed at runtime via compose `env_file`, not baked into image
.env
.env.local
.env.*.local

# TS build artifact
tsconfig.tsbuildinfo

# Docker meta (no need to send these inside the build context back to the daemon)
docker-compose.yml
docker-compose.*.yml
Dockerfile
.dockerignore
