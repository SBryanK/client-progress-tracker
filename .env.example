# ─── Database ─────────────────────────────────────────────────────────────────
# PRODUCTION (Vercel):
#   Create a Vercel Postgres store (Project → Storage → Create → Postgres).
#   Vercel will AUTOMATICALLY inject these two vars into every deploy:
#       POSTGRES_PRISMA_URL        ← pooled URL, used at runtime (Prisma Client)
#       POSTGRES_URL_NON_POOLING   ← direct URL, used by `prisma db push`
#   You do NOT need to copy them here or set them in Vercel manually.
#
# LOCAL DEV (SQLite):
#   Use an ABSOLUTE path. Prisma's CLI resolves relative `file:` URLs against
#   the schema's directory (prisma/), but the Prisma Client at runtime resolves
#   them against process.cwd(). That mismatch silently creates two different
#   DBs (prisma/dev.db ↔ prisma/prisma/dev.db). An absolute path eliminates the
#   ambiguity. Replace the path below with the absolute path on YOUR machine.
DATABASE_URL="file:/absolute/path/to/client-progress-tracker/data/app.db"

# LOCAL DEV (Postgres) or Vercel mirror — uncomment and use either pair:
POSTGRES_PRISMA_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require&pgbouncer=true&connect_timeout=15"
POSTGRES_URL_NON_POOLING="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"

# ─── NextAuth ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="change-me-change-me-change-me-change-me"
AUTH_TRUST_HOST="true"
# Canonical URL NextAuth v5 uses for callbacks. On Vercel this should be your
# production domain (custom domain preferred, e.g. https://client-tracker.sbryank.com)
AUTH_URL="https://client-tracker.sbryank.com"

# Public base URL (used by share links and absolute URLs)
NEXT_PUBLIC_APP_URL="https://client-tracker.sbryank.com"

# ─── Role-based access ────────────────────────────────────────────────────────
# Sign-in uses USERNAME + password (not email). List one or more usernames here
# that are allowed to sign in as OWNER. Anyone else can still READ everything
# (the landing page is public).
OWNER_USERNAMES="sbryank"

# Legacy fallback. If OWNER_USERNAMES is not set, the public read path falls
# back to looking up users by email. New installs should prefer OWNER_USERNAMES
# above — keep OWNER_EMAILS only when migrating an old deployment.
OWNER_EMAILS=""

# Shared password for all owner usernames above (first-run only — change after).
OWNER_PASSWORD="change-me-on-first-run"

# Display name used for owner records on first seed.
OWNER_NAME="Bryan"

# Public site title + tagline shown on the landing page.
NEXT_PUBLIC_SITE_OWNER_NAME="Bryan"
NEXT_PUBLIC_SITE_TAGLINE="Weekly client progress — read-only public view."

# ─── AI Assistant (Anthropic Claude) ──────────────────────────────────────────
# Used by /api/ai/summarize for the landing-page AI panel.
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=""

# ─── External CRM deep-link ───────────────────────────────────────────────────
# URL opened by the "Open in CRM ↗" action on every client detail page.
# Defaults to the canonical Tencent CSIG CRM customisation page if unset.
NEXT_PUBLIC_CRM_URL="https://csigcrm.woa.com/index.action#/spa/customize.action?belongId=2078245914263586"

# ─── Bucket defaults ──────────────────────────────────────────────────────────
# Default bucket pre-selected in the "New client" form. One of:
#   PRIMARY | ASSIST | AKAMAI | INACTIVE
# Leave unset to default to PRIMARY. The form still lets you override
# the value per-client every time, so this is purely a convenience
# pre-selection — no row is ever silently bucketed without your input.
NEXT_PUBLIC_DEFAULT_BUCKET="PRIMARY"
