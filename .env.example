# ─── Database ─────────────────────────────────────────────────────────────────
# PRODUCTION (Vercel):
#   Create a Vercel Postgres store (Project → Storage → Create → Postgres).
#   Vercel will AUTOMATICALLY inject these two vars into every deploy:
#       POSTGRES_PRISMA_URL        ← pooled URL, used at runtime (Prisma Client)
#       POSTGRES_URL_NON_POOLING   ← direct URL, used by `prisma db push`
#   You do NOT need to copy them here or set them in Vercel manually.
#
# LOCAL DEV:
#   Option A — point at the same Vercel Postgres DB (pull with `vercel env pull`)
#   Option B — spin up a local Postgres (docker run -e POSTGRES_PASSWORD=pw \
#              -p 5432:5432 -d postgres:16) and set both vars below.
POSTGRES_PRISMA_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require&pgbouncer=true&connect_timeout=15"
POSTGRES_URL_NON_POOLING="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"

# ─── NextAuth ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="change-me-change-me-change-me-change-me"
AUTH_TRUST_HOST="true"
# Canonical URL NextAuth v5 uses for callbacks. On Vercel this should be your
# production domain (custom domain preferred, e.g. https://client-tracker.sbryank.com)
AUTH_URL="https://client-tracker.sbryank.com"

# Public base URL (used by share links and absolute URLs)
NEXT_PUBLIC_APP_URL="https://client-tracker.sbryank.com"

# ─── Role-based access ────────────────────────────────────────────────────────
# Comma-separated list of emails that can sign in and edit data.
# Anyone else can still READ everything (the landing page is public).
OWNER_EMAILS="you@example.com"

# Shared password for all owner emails above (first-run only — change after).
OWNER_PASSWORD="change-me-on-first-run"

# Display name used for owner records on first seed.
OWNER_NAME="Bryan"

# Public site title + tagline shown on the landing page.
NEXT_PUBLIC_SITE_OWNER_NAME="Bryan"
NEXT_PUBLIC_SITE_TAGLINE="Weekly client progress — read-only public view."

# ─── AI Assistant (Anthropic Claude) ──────────────────────────────────────────
# Used by /api/ai/summarize for the landing-page AI panel.
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=""
