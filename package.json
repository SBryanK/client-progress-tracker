{
  "name": "client-progress-tracker",
  "version": "0.1.0",
  "private": true,
  "description": "Weekly Client Progress Tracker — replaces a Word-based client tracker with a responsive, multi-user web app (Next.js 15 + Prisma + SQLite).",
  "scripts": {
    "dev": "next dev -H 0.0.0.0 -p 3000",
    "dev:clean": "rm -rf .next node_modules/.cache tsconfig.tsbuildinfo && next dev -H 0.0.0.0 -p 3000",
    "clean": "rm -rf .next node_modules/.cache tsconfig.tsbuildinfo",
    "reinstall": "rm -rf .next node_modules/.cache node_modules package-lock.json tsconfig.tsbuildinfo && npm install",
    "build": "prisma generate && prisma db push --accept-data-loss --skip-generate && next build",
    "start": "next start -H 0.0.0.0 -p 3000",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev --name init",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:reassign-owner": "tsx scripts/reassign-owner.ts",
    "import:docx": "tsx scripts/import-docx.ts",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.4",
    "@prisma/client": "^6.1.0",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "docx": "^9.1.0",
    "jspdf": "^2.5.2",
    "jspdf-autotable": "^3.8.4",
    "lucide-react": "^0.469.0",
    "mammoth": "^1.8.0",
    "next": "^15.1.3",
    "next-auth": "5.0.0-beta.25",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.5.5",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.15",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.3",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "postcss": "^8.4.49",
    "prisma": "^6.1.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
